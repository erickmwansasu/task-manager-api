<!DOCTYPE html>
<html lang="en">

<%- include('../../partials/admin/head.ejs') %>

<%- include('../../partials/admin/nav.ejs') %>

<body>
    <p>All Users</p>

    <% if (allUsers.length > 0) {
        allUsers.forEach(user => { %>
            <p><%= user.email %></p>
            <p><%= user.roles %></p>
       <% });
    } else { %>
        <p>No users found</p>
   <% } %>

   <br>
   <a href="/logout">Log out</a>


<%- include('../../partials/admin/footer.ejs') %>

</body>
</html>