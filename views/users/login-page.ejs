<!DOCTYPE html>
<html lang="en">

<%-  include('../../partials/users/head.ejs', { viewCss: 'login.css' }) %>

<%-  include('../../partials/users/nav.ejs') %>

<body>
    <div id="login-container" class="login-container">
        <form action="/user-login" method="POST" class="login-form">
            <h2>Sign In</h2><br>
            <span>Email</span><br>
            <input type="email" id="email" name="email" placeholder=""><br><br>

            <span>Password</span><br>
            <input type="password" id="password" name="password" placeholder=""><br><br>

            <button id="signin" class="signin">Sign In</button>
            <p>Don't have an account? <a href="/register-page">Register</a></p>
        </form>
    </div>

    <%- include('../../partials/users/footer.ejs') %>

</body>
</html>